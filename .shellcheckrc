# config de shellcheck del repo. la leen tanto la corrida manual como el CI.

# seguir los `source` con ruta resoluble (configuracion/parametros.sh, scripts/lib/*.sh)
# para que shellcheck conozca las variables y no las marque como no asignadas.
external-sources=true

# conda.sh se sourcea con ruta dinámica ($(conda info --base)/etc/profile.d/conda.sh);
# shellcheck no puede seguirla y no es un problema. SC1091 = "no pude seguir el source".
disable=SC1091
