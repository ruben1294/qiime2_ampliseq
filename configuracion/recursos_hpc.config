/*
 * =============================================================================
 *  recursos_hpc.config
 * -----------------------------------------------------------------------------
 *  Recursos para correr en un clúster con SLURM: Nextflow manda cada tarea a la
 *  cola en vez de correrla aquí. Trae los valores del servidor de OMICA (CICESE).
 *  Lo aplica el script 03 con  -profile docker -c este_archivo.
 *
 *  Modelo en OMICA: el job maestro (Nextflow) corre en nodo5 y solo orquesta;
 *  no necesita Docker. Cada tarea se manda a SLURM y corre con Docker en los
 *  nodos que lo tienen (nodo27 y nodo28), fijados con --nodelist.
 * =============================================================================
 */

// Cada tarea se envía como un trabajo de SLURM. 'queue' es la partición y
// 'clusterOptions' la cuenta y el fijado de nodos. Como Docker solo está en
// nodo27 y nodo28, --nodelist limita las tareas a esos nodos (SLURM elige uno).
// 'resourceLimits' es el techo por tarea (un nodo: 24 CPU, 120 GB).
process {
    executor = 'slurm'
    queue = 'cicese'
    // partición / cola
    clusterOptions = '--account=metagenomica --nodelist=nodo27,nodo28'
    // cuenta de SLURM y nodos con Docker. Para apartar el nodo entero por tarea
    // añade --exclusive (más aislamiento, pero solo 2 tareas a la vez).

    resourceLimits = [cpus: 24, memory: '120.GB', time: '140.h']
    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 140, 143, 247] ? 'retry' : 'finish' }
    maxRetries = 2
}

// 'queueSize' = cuántos trabajos pueden estar en la cola a la vez. Con solo dos
// nodos de cómputo no conviene pasarse; la RAM se reparte entre las tareas
// activas. 'submitRateLimit' evita saturar al planificador al enviarlos.
executor {
    queueSize = 4
    submitRateLimit = '10/1min'
}

// Opciones de Docker (solo aplican con -profile docker). '-u' mapea tu usuario
// dentro del contenedor para que los archivos en LUSTRE no queden como root.
docker {
    runOptions = '-u $(id -u):$(id -g)'
}

// Respaldo: solo aplica si fuerzas -profile singularity/apptainer. 'autoMounts'
// monta las rutas necesarias (p. ej. LUSTRE).
singularity {
    autoMounts = true
}
