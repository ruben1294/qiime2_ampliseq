/*
 * =============================================================================
 *  recursos_local.config
 * -----------------------------------------------------------------------------
 *  Límites de recursos para correr en tu computadora.
 *  Ajusta los topes a tu equipo. Dejamos margen para el sistema y para WSL para
 *  que la compu no se congele. Lo aplica el script 03 con  -c este_archivo.
 * =============================================================================
 */

// 'resourceLimits' es el límite superior de recursos. Ninguna tarea va a pedir más que esto,
// aunque su receta original pida más. 'errorStrategy' + 'maxRetries' reintentan
// las tareas que mueren por falta de memoria (137/140), subiendo recursos.
process {
    resourceLimits = [cpus: 10, memory: '13.GB', time: '48.h']
    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 140, 143, 247] ? 'retry' : 'finish' }
    maxRetries = 2
}

// Corre en esta misma compu. 'queueSize' limita cuántas tareas van en paralelo
// para no saturar la RAM (cada una puede usar varios GB).
executor {
    name = 'local'
    cpus = 10
    memory = '13 GB'
    queueSize = 4
}

// Solo aplica con -profile singularity/apptainer; 'autoMounts' monta las rutas
// necesarias.
singularity {
    autoMounts = true
}
